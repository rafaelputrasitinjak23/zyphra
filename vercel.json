{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "{views/**,public/**,config/**,models/**,routes/**,middleware/**,services/**,utils.js}",
      "maxDuration": 30
    }
  }
}
