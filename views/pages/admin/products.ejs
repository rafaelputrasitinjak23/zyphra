<section class="mx-auto max-w-7xl px-4 py-10">
  <div class="flex items-center justify-between gap-4"><h1 class="text-3xl font-black text-slate-950">Kelola Produk</h1><a href="/admin/products/new" class="btn-primary">Tambah Produk</a></div>
  <div class="mt-6 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-soft"><div class="overflow-x-auto"><table class="min-w-full text-left text-sm"><thead class="bg-slate-50 text-xs uppercase text-slate-500"><tr><th class="px-5 py-4">Produk</th><th class="px-5 py-4">Harga</th><th class="px-5 py-4">Stok</th><th class="px-5 py-4">Status</th><th class="px-5 py-4">Aksi</th></tr></thead><tbody class="divide-y divide-slate-100"><% products.forEach((product)=>{ %><tr><td class="px-5 py-4"><div class="flex items-center gap-3"><img src="<%= product.imageUrl %>" class="h-12 w-16 rounded-xl object-cover"><div><p class="font-black"><%= product.name %></p><p class="text-xs text-slate-500"><%= product.category %></p></div></div></td><td class="px-5 py-4"><%= formatRupiah(product.price) %></td><td class="px-5 py-4"><%= product.stock %></td><td class="px-5 py-4"><%= product.active ? 'Aktif' : 'Nonaktif' %></td><td class="px-5 py-4"><div class="flex gap-2"><a class="btn-soft !py-2" href="/admin/products/<%= product._id %>/edit">Edit</a><form action="/admin/products/<%= product._id %>/delete" method="post" onsubmit="return confirm('Hapus produk?')"><button class="btn-soft !py-2 text-rose-600">Hapus</button></form></div></td></tr><% }) %></tbody></table></div></div>
</section>
