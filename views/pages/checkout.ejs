<section class="mx-auto max-w-5xl px-4 py-10">
  <h1 class="text-3xl font-black text-slate-950">Checkout</h1>
  <div class="mt-6 card p-6">
    <% items.forEach((item) => { %>
      <div class="flex items-center justify-between border-b border-slate-100 py-4 last:border-0">
        <div><h2 class="font-bold"><%= item.product.name %></h2><p class="text-sm text-slate-500"><%= item.qty %> x <%= formatRupiah(item.product.price) %></p></div>
        <p class="font-black"><%= formatRupiah(item.qty * item.product.price) %></p>
      </div>
    <% }) %>
    <div class="mt-6 flex items-center justify-between rounded-2xl bg-slate-50 p-5 text-xl font-black"><span>Total</span><span class="text-blue-700"><%= formatRupiah(total) %></span></div>
    <p class="mt-4 text-sm leading-6 text-slate-500">Demo checkout ini langsung menandai pembayaran sebagai berhasil. Untuk produksi, hubungkan ke payment gateway seperti Midtrans/Xendit.</p>
    <form action="/checkout" method="post" class="mt-6"><button class="btn-primary w-full">Bayar Sekarang</button></form>
  </div>
</section>
