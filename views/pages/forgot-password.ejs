<section class="mx-auto grid max-w-6xl gap-8 px-4 py-12 lg:grid-cols-2 lg:items-center">
  <div>
    <span class="badge">Password Recovery</span>
    <h1 class="mt-5 text-4xl font-black text-slate-50 md:text-5xl">Ganti password lewat email.</h1>
    <p class="mt-4 text-lg leading-8 text-slate-400">Masukkan email akun Zyphra. Link reset password akan dikirim menggunakan Nodemailer.</p>
  </div>
  <div class="card p-7 md:p-9">
    <form action="/forgot-password" method="post" class="space-y-4">
      <label class="block"><span class="label">Email</span><div class="relative mt-2"><svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M4 4h16v16H4z"/><path stroke-width="2" d="m4 7 8 6 8-6"/></svg><input class="input pl-12" name="email" type="email" required></div></label>
      <button class="btn-primary w-full" type="submit">Kirim Link Reset</button>
    </form>
    <p class="mt-5 text-center text-sm text-slate-400">Ingat password? <a class="font-bold text-blue-300" href="/login">Login</a></p>
  </div>
</section>
