<section class="mx-auto max-w-6xl px-4 py-10">
  <h1 class="text-3xl font-black text-slate-950">Keranjang</h1>
  <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_360px]">
    <div class="space-y-4">
      <% if (!items.length) { %><div class="card p-8 text-center text-slate-500">Keranjang kosong.</div><% } %>
      <% items.forEach((item) => { %>
        <div class="card flex flex-col gap-4 p-4 sm:flex-row sm:items-center">
          <img src="<%= item.product.imageUrl %>" class="h-28 w-full rounded-2xl object-cover sm:w-36" alt="<%= item.product.name %>">
          <div class="flex-1">
            <h2 class="font-black text-slate-950"><%= item.product.name %></h2>
            <p class="mt-1 text-sm text-slate-500"><%= formatRupiah(item.product.price) %> • Stok <%= item.product.stock %></p>
            <div class="mt-4 flex flex-wrap gap-2">
              <form action="/cart/update/<%= item.product._id %>" method="post" class="flex gap-2">
                <input class="input !w-24 !py-2" name="qty" type="number" min="1" max="<%= item.product.stock %>" value="<%= item.qty %>">
                <button class="btn-soft !py-2">Update</button>
              </form>
              <form action="/cart/remove/<%= item.product._id %>" method="post"><button class="btn-soft !py-2 text-rose-600">Hapus</button></form>
            </div>
          </div>
          <p class="font-black text-blue-700"><%= formatRupiah(item.product.price * item.qty) %></p>
        </div>
      <% }) %>
    </div>
    <aside class="card h-fit p-6">
      <h2 class="text-xl font-black text-slate-950">Ringkasan</h2>
      <div class="mt-5 flex justify-between border-t border-slate-100 pt-5 font-black"><span>Total</span><span class="text-blue-700"><%= formatRupiah(total) %></span></div>
      <a href="/checkout" class="btn-primary mt-6 w-full <%= !items.length ? 'pointer-events-none opacity-50' : '' %>">Lanjut Checkout</a>
    </aside>
  </div>
</section>
