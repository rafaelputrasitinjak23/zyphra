<section class="mx-auto max-w-7xl px-4 py-10">
  <div class="grid gap-8 lg:grid-cols-2">
    <div class="card overflow-hidden"><img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="h-[420px] w-full object-cover"></div>
    <div class="card p-7 md:p-9">
      <span class="rounded-full bg-blue-500/10 px-3 py-1 text-sm font-bold text-blue-300"><%= product.category %></span>
      <h1 class="mt-5 text-3xl font-black tracking-tight text-slate-50 md:text-5xl"><%= product.name %></h1>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-slate-400">
        <span class="inline-flex items-center gap-1 text-amber-300"><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.18 3.64a1 1 0 0 0 .95.69h3.83c.97 0 1.37 1.24.59 1.8l-3.1 2.26a1 1 0 0 0-.36 1.12l1.18 3.64c.3.92-.76 1.69-1.54 1.12l-3.1-2.25a1 1 0 0 0-1.18 0l-3.1 2.25c-.78.57-1.84-.2-1.54-1.12l1.18-3.64a1 1 0 0 0-.36-1.12L2.48 9.06c-.78-.56-.38-1.8.59-1.8H6.9a1 1 0 0 0 .95-.69l1.18-3.64z"/></svg><%= reviewSummary.average ? reviewSummary.average.toFixed(1) : '0.0' %></span>
        <span>•</span><span><%= reviewSummary.count %> review</span><span>•</span><span><%= product.sold %> terjual</span>
      </div>
      <p class="mt-4 text-lg leading-8 text-slate-400"><%= product.description %></p>
      <div class="mt-7 grid gap-3 rounded-2xl bg-slate-950/60 p-5 sm:grid-cols-3">
        <div><p class="text-xs font-bold uppercase text-slate-500">Harga</p><p class="mt-1 font-black text-blue-300"><%= formatRupiah(product.price) %></p></div>
        <div><p class="text-xs font-bold uppercase text-slate-500">Stok</p><p class="mt-1 font-black text-slate-100"><%= product.stock %></p></div>
        <div><p class="text-xs font-bold uppercase text-slate-500">Terjual</p><p class="mt-1 font-black text-slate-100"><%= product.sold %></p></div>
      </div>
      <form action="/cart/add/<%= product._id %>" method="post" class="mt-7 flex flex-col gap-3 sm:flex-row">
        <input class="input sm:w-28" type="number" name="qty" min="1" max="<%= product.stock %>" value="1" <%= product.stock < 1 ? 'disabled' : '' %>>
        <button class="btn-primary flex-1" <%= product.stock < 1 ? 'disabled' : '' %>><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13 5.4 5M7 13l-2 9m12-9 2 9M9 22h.01M15 22h.01"/></svg>Tambah ke Keranjang</button>
      </form>
    </div>
  </div>

  <div id="reviews" class="mt-10 grid gap-6 lg:grid-cols-[.9fr_1.1fr]">
    <div class="card p-6">
      <h2 class="text-2xl font-black text-slate-50">Review Produk</h2>
      <p class="mt-2 text-sm text-slate-400">Rating rata-rata <b class="text-amber-300"><%= reviewSummary.average ? reviewSummary.average.toFixed(1) : '0.0' %>/5</b> dari <%= reviewSummary.count %> review.</p>
      <% if (currentUser && canReview) { %>
        <form class="mt-5 grid gap-4" method="post" action="/product/<%= product._id %>/review">
          <label><span class="label">Rating</span><select class="input mt-2" name="rating"><% [5,4,3,2,1].forEach((rating)=>{ %><option value="<%= rating %>" <%= existingReview?.rating === rating ? 'selected' : '' %>><%= rating %> Bintang</option><% }) %></select></label>
          <label><span class="label">Komentar</span><textarea class="input mt-2 min-h-32" name="comment" maxlength="600" placeholder="Bagikan pengalaman Anda setelah membeli produk ini..." required><%= existingReview?.comment || '' %></textarea></label>
          <button class="btn-primary"><%= existingReview ? 'Update Review' : 'Kirim Review' %></button>
        </form>
      <% } else if (currentUser) { %>
        <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/60 p-4 text-sm text-slate-400">Anda bisa memberi review setelah membeli produk ini.</div>
      <% } else { %>
        <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/60 p-4 text-sm text-slate-400">Login dan beli produk ini untuk memberi review.</div>
      <% } %>
    </div>

    <div class="space-y-4">
      <% if (!reviews.length) { %><div class="card p-8 text-center text-slate-500">Belum ada review untuk produk ini.</div><% } %>
      <% reviews.forEach((review)=>{ %>
        <div class="card p-5">
          <div class="flex items-start justify-between gap-3"><div><p class="font-black text-slate-100"><%= review.user?.name || 'User Zyphra' %></p><p class="text-xs text-slate-500"><%= review.createdAt.toLocaleString('id-ID') %></p></div><span class="rounded-full bg-amber-400/10 px-3 py-1 text-xs font-black text-amber-300"><%= review.rating %> ★</span></div>
          <p class="mt-3 text-sm leading-6 text-slate-400"><%= review.comment %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
