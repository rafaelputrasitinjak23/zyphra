<section class="mx-auto max-w-xl px-4 py-12">
  <div class="card p-7 md:p-9">
    <h1 class="text-3xl font-black text-slate-50">Ganti Password</h1>
    <% if (invalid) { %>
      <p class="mt-4 text-slate-400">Link reset password tidak valid atau sudah kedaluwarsa.</p>
      <a class="btn-primary mt-6" href="/forgot-password">Minta Link Baru</a>
    <% } else { %>
      <form action="/reset-password" method="post" class="mt-6 space-y-4">
        <input type="hidden" name="token" value="<%= token %>">
        <label class="block"><span class="label">Password Baru</span><input class="input mt-2" name="password" type="password" minlength="10" required></label>
        <label class="block"><span class="label">Konfirmasi Password Baru</span><input class="input mt-2" name="confirmPassword" type="password" minlength="10" required></label>
        <p class="text-xs leading-6 text-slate-500">Minimal 10 karakter, huruf besar, huruf kecil, angka, simbol, dan tidak memakai kata umum.</p>
        <button class="btn-primary w-full" type="submit">Simpan Password Baru</button>
      </form>
    <% } %>
  </div>
</section>
