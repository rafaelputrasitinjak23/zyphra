<section class="mx-auto max-w-5xl px-4 py-10">
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-widest text-blue-400">Invoice Otomatis</p>
      <h1 class="mt-2 text-3xl font-black text-slate-50"><%= order.invoiceNumber || ('INV-' + order._id.toString().slice(-8).toUpperCase()) %></h1>
      <p class="mt-2 text-sm text-slate-400">Dibuat pada <%= order.createdAt.toLocaleString('id-ID') %></p>
    </div>
    <div class="flex gap-2"><button onclick="window.print()" class="btn-primary">Print Invoice</button><a href="<%= currentUser.role === 'admin' ? '/admin/orders' : '/account' %>" class="btn-soft">Kembali</a></div>
  </div>

  <div class="mt-8 card overflow-hidden">
    <div class="grid gap-6 border-b border-slate-800 p-6 md:grid-cols-2">
      <div>
        <p class="text-xs font-black uppercase tracking-widest text-slate-500">Dari</p>
        <h2 class="mt-2 text-2xl font-black text-slate-50">Zyphra</h2>
        <p class="mt-2 text-sm leading-6 text-slate-400">Marketplace produk digital untuk script website, bot, dan source code siap pakai.</p>
      </div>
      <div class="md:text-right">
        <p class="text-xs font-black uppercase tracking-widest text-slate-500">Untuk</p>
        <h2 class="mt-2 text-xl font-black text-slate-50"><%= order.user?.name || currentUser.name %></h2>
        <p class="mt-1 text-sm text-slate-400"><%= order.user?.email || currentUser.email %></p>
        <span class="mt-3 inline-flex rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-xs font-black uppercase text-blue-300"><%= order.paymentStatus %></span>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full text-left text-sm">
        <thead class="bg-slate-950/60 text-xs uppercase text-slate-500"><tr><th class="px-6 py-4">Produk</th><th class="px-6 py-4 text-center">Qty</th><th class="px-6 py-4 text-right">Harga</th><th class="px-6 py-4 text-right">Subtotal</th></tr></thead>
        <tbody class="divide-y divide-slate-800">
          <% order.items.forEach((item)=>{ %>
            <tr>
              <td class="px-6 py-4"><div class="flex items-center gap-3"><img src="<%= item.imageUrl %>" class="h-12 w-16 rounded-xl object-cover" alt="<%= item.name %>"><div><p class="font-black text-slate-100"><%= item.name %></p><p class="text-xs text-slate-500">Produk digital</p></div></div></td>
              <td class="px-6 py-4 text-center"><%= item.qty %></td>
              <td class="px-6 py-4 text-right"><%= formatRupiah(item.price) %></td>
              <td class="px-6 py-4 text-right font-black"><%= formatRupiah(item.price * item.qty) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-6 border-t border-slate-800 p-6 md:grid-cols-[1fr_320px]">
      <div class="rounded-2xl border border-slate-800 bg-slate-950/50 p-4 text-sm leading-6 text-slate-400">
        <p class="font-black text-slate-100">Catatan</p>
        <p class="mt-1">File produk tidak dibuka langsung dari URL sumber. User dapat mengunduh produk dari halaman akun selama memiliki akses pembelian.</p>
      </div>
      <div class="space-y-3">
        <div class="flex justify-between text-sm"><span class="text-slate-400">Metode</span><span class="font-bold"><%= order.paymentMethod %></span></div>
        <div class="flex justify-between text-sm"><span class="text-slate-400">Tanggal bayar</span><span class="font-bold"><%= order.paidAt ? order.paidAt.toLocaleString('id-ID') : '-' %></span></div>
        <div class="flex justify-between border-t border-slate-800 pt-3 text-xl font-black"><span>Total</span><span class="text-blue-300"><%= formatRupiah(order.total) %></span></div>
      </div>
    </div>
  </div>
</section>
