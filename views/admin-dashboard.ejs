<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/bg') %>
  <%- include('partials/header') %>

  <main class="mx-auto w-[92%] max-w-7xl py-10">
    <section class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end">
      <div>
        <p class="mb-3 inline-block rounded-full bg-white px-4 py-2 text-sm font-black text-blue-700 shadow-sm ring-1 ring-blue-100">Admin Dashboard</p>
        <h1 class="text-4xl font-black tracking-[-0.04em] md:text-6xl">Kelola semua share.</h1>
        <p class="mt-3 max-w-2xl font-semibold leading-relaxed text-slate-500">Tambah script dengan gambar dan URL download, atau code dengan syntax highlight dan fitur copy.</p>
      </div>
      <a href="/admin/add" class="btn rounded-2xl bg-blue-600 px-6 py-4 text-center font-black text-white shadow-xl shadow-blue-600/20">+ Tambah Share</a>
    </section>

    <section class="mb-8 grid gap-4 md:grid-cols-4">
      <div class="soft-card rounded-3xl p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-blue-50 text-blue-700"><%- iconSvg('file') %></span>
          <p class="text-3xl font-black"><%= formatNumber(stats.totalShares) %></p>
        </div>
      </div>
      <div class="soft-card rounded-3xl p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-violet-50 text-violet-700"><%- iconSvg('view') %></span>
          <p class="text-3xl font-black"><%= formatNumber(stats.totalViews) %></p>
        </div>
      </div>
      <div class="soft-card rounded-3xl p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-emerald-50 text-emerald-700"><%- iconSvg('download') %></span>
          <p class="text-3xl font-black"><%= formatNumber(stats.totalDownloads) %></p>
        </div>
      </div>
      <div class="soft-card rounded-3xl p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-orange-50 text-orange-700"><%- iconSvg('copy') %></span>
          <p class="text-3xl font-black"><%= formatNumber(stats.totalCopies) %></p>
        </div>
      </div>
    </section>

    <section class="soft-card overflow-hidden rounded-[2rem]">
      <div class="flex flex-col justify-between gap-3 border-b border-slate-200 p-5 md:flex-row md:items-center">
        <div>
          <h2 class="text-2xl font-black tracking-tight">Data Share</h2>
          <p class="text-sm font-semibold text-slate-500">Edit, hapus, dan lihat status publikasi.</p>
        </div>
        <a href="/" class="rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-700 ring-1 ring-slate-200">Lihat Website</a>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[900px] text-left text-sm">
          <thead class="bg-slate-50 text-xs font-black uppercase text-slate-500">
            <tr>
              <th class="px-5 py-4">Judul</th>
              <th class="px-5 py-4">Kategori</th>
              <th class="px-5 py-4">Tipe</th>
              <th class="px-5 py-4">Statistik</th>
              <th class="px-5 py-4">Status</th>
              <th class="px-5 py-4">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% if (!shares.length) { %>
              <tr>
                <td colspan="6" class="px-5 py-10 text-center font-bold text-slate-500">Belum ada share. Klik tombol tambah untuk membuat data pertama.</td>
              </tr>
            <% } %>
            <% shares.forEach((share) => { %>
              <tr class="bg-white/60 align-top">
                <td class="px-5 py-4">
                  <p class="font-black text-slate-950"><%= share.title %></p>
                  <p class="mt-1 line-clamp-2 max-w-md text-xs font-semibold text-slate-500"><%= share.shortDescription || share.description || '-' %></p>
                </td>
                <td class="px-5 py-4 font-black text-slate-700"><%= categoryLabels[share.category] %></td>
                <td class="px-5 py-4">
                  <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-black text-blue-700 ring-1 ring-blue-100"><%= share.type === 'code' ? 'Code' : 'Script' %></span>
                </td>
                <td class="px-5 py-4 text-xs font-bold text-slate-500">
                  <div class="grid gap-2">
                    <span class="inline-flex items-center gap-1.5"><%- iconSvg('view', 'h-4 w-4') %><%= formatNumber(share.views) %></span>
                    <span class="inline-flex items-center gap-1.5"><%- iconSvg('download', 'h-4 w-4') %><%= formatNumber(share.downloads) %></span>
                    <span class="inline-flex items-center gap-1.5"><%- iconSvg('copy', 'h-4 w-4') %><%= formatNumber(share.copies) %></span>
                  </div>
                </td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <% if (share.isPublished) { %>
                      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700 ring-1 ring-emerald-100">Published</span>
                    <% } else { %>
                      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600 ring-1 ring-slate-200">Draft</span>
                    <% } %>
                    <% if (share.isFeatured) { %>
                      <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-black text-orange-700 ring-1 ring-orange-100">Featured</span>
                    <% } %>
                  </div>
                </td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <a href="/share/<%= share.slug %>" class="rounded-xl bg-white px-3 py-2 text-xs font-black text-slate-700 ring-1 ring-slate-200">View</a>
                    <a href="/admin/edit/<%= share._id %>" class="rounded-xl bg-blue-600 px-3 py-2 text-xs font-black text-white">Edit</a>
                    <form method="POST" action="/admin/delete/<%= share._id %>" onsubmit="return confirm('Hapus share ini?')">
                      <button class="rounded-xl bg-red-600 px-3 py-2 text-xs font-black text-white">Hapus</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
