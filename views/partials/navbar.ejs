<header class="sticky top-0 z-40 border-b border-slate-800/80 bg-slate-950/82 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-3 font-black tracking-tight text-slate-50">
      <span class="grid h-10 w-10 place-items-center rounded-2xl bg-blue-600 text-white shadow-soft">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12l8-4.5M12 12v9M12 12 4 7.5"/></svg>
      </span>
      <span>Zyphra</span>
    </a>
    <button class="rounded-xl border border-slate-800 p-2 text-slate-200 md:hidden" data-menu-btn>
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <div class="hidden items-center gap-2 md:flex" data-menu>
      <a class="navlink" href="/"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>Produk</a>
      <a class="navlink" href="/report"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h7m-9 8 4-4h8a4 4 0 0 0 4-4V7a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v5a4 4 0 0 0 4 4"/></svg>Report</a>
      <% if (currentUser) { %>
        <a class="navlink" href="/cart"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l2 13h11l2-9H6"/></svg>Keranjang <span class="ml-1 rounded-full bg-blue-500/10 px-2 py-0.5 text-xs text-blue-200"><%= cartCount %></span></a>
        <a class="navlink" href="/account">Akun</a>
        <% if (isAdmin) { %><a class="navlink" href="/admin">Admin</a><% } %>
        <form action="/logout" method="post"><button class="rounded-xl border border-slate-800 px-4 py-2 text-sm font-semibold text-slate-200 hover:bg-slate-900">Logout</button></form>
      <% } else { %>
        <a class="navlink" href="/login">Login</a>
        <a class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-soft hover:bg-blue-700" href="/register">Register</a>
      <% } %>
    </div>
  </nav>
  <div class="hidden border-t border-slate-800 bg-slate-950 px-4 py-3 md:hidden" data-mobile-menu>
    <div class="mx-auto flex max-w-7xl flex-col gap-2">
      <a class="navlink" href="/">Produk</a>
      <a class="navlink" href="/report">Report</a>
      <% if (currentUser) { %><a class="navlink" href="/cart">Keranjang</a><a class="navlink" href="/account">Akun</a><% if (isAdmin) { %><a class="navlink" href="/admin">Admin</a><% } %><form action="/logout" method="post"><button class="navlink w-full text-left">Logout</button></form><% } else { %><a class="navlink" href="/login">Login</a><a class="navlink" href="/register">Register</a><% } %>
    </div>
  </div>
</header>
