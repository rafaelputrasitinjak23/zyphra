<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/bg') %>
  <%- include('partials/header') %>

  <main class="mx-auto w-[92%] max-w-7xl py-10">
    <section class="grid gap-8 lg:grid-cols-[1fr_360px]">
      <article class="glass overflow-hidden rounded-[2rem] p-4 md:p-6">
        <div class="mb-6 flex flex-wrap items-center gap-2">
          <a href="/" class="rounded-full bg-white px-4 py-2 text-sm font-black text-slate-600 ring-1 ring-slate-200">← Home</a>
          <span class="rounded-full bg-blue-50 px-4 py-2 text-sm font-black text-blue-700 ring-1 ring-blue-100"><%= share.type === 'code' ? 'Code' : 'Script' %></span>
          <span class="rounded-full bg-slate-50 px-4 py-2 text-sm font-black text-slate-700 ring-1 ring-slate-200"><%= categoryLabels[share.category] %></span>
          <% if (share.isFeatured) { %>
            <span class="rounded-full bg-emerald-50 px-4 py-2 text-sm font-black text-emerald-700 ring-1 ring-emerald-100">Featured</span>
          <% } %>
        </div>

        <h1 class="max-w-4xl text-4xl font-black leading-tight tracking-[-0.04em] md:text-6xl"><%= share.title %></h1>
        <p class="mt-4 max-w-3xl text-lg font-semibold leading-relaxed text-slate-600"><%= share.shortDescription || 'Detail share script dan code.' %></p>

        <div class="mt-7 grid gap-4 sm:grid-cols-3">
          <div class="soft-card rounded-3xl p-5">
            <div class="flex items-center gap-3 text-slate-700">
              <span class="grid h-11 w-11 place-items-center rounded-2xl bg-blue-50 text-blue-700"><%- iconSvg('view') %></span>
              <p class="text-3xl font-black"><%= formatNumber(share.views) %></p>
            </div>
          </div>
          <div class="soft-card rounded-3xl p-5">
            <div class="flex items-center gap-3 text-slate-700">
              <span class="grid h-11 w-11 place-items-center rounded-2xl bg-emerald-50 text-emerald-700"><%- iconSvg('download') %></span>
              <p class="text-3xl font-black"><%= formatNumber(share.downloads) %></p>
            </div>
          </div>
          <div class="soft-card rounded-3xl p-5">
            <div class="flex items-center gap-3 text-slate-700">
              <span class="grid h-11 w-11 place-items-center rounded-2xl bg-violet-50 text-violet-700"><%- iconSvg('copy') %></span>
              <p class="text-3xl font-black" data-copy-count><%= formatNumber(share.copies) %></p>
            </div>
          </div>
        </div>

        <% if (share.type === 'script') { %>
          <div class="mt-8 overflow-hidden rounded-[2rem] bg-slate-950">
            <img src="<%= share.imageUrl || defaultImage(share.category) %>" alt="<%= share.title %>" class="max-h-[520px] w-full object-cover opacity-95">
          </div>
        <% } else { %>
          <div class="code-window mt-8 overflow-hidden rounded-[2rem] bg-slate-950 text-white ring-1 ring-slate-900/10">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/10 px-5 py-4">
              <div>
                <p class="text-sm font-black text-blue-300"><%= languageLabels[share.language] || share.language %></p>
                <p class="text-xs font-bold text-white/45">Preview code siap copy</p>
              </div>
              <button data-copy-code="#mainCode" data-share-id="<%= share._id %>" class="btn inline-flex items-center justify-center gap-2 rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-950">
                <%- iconSvg('copy', 'h-4 w-4') %>
                Copy
              </button>
            </div>
            <pre class="max-h-[680px] overflow-auto p-5 text-sm"><code id="mainCode" class="language-<%= prismAliases[share.language] || share.language || 'text' %>"><%- escapeHtml(share.code) %></code></pre>
          </div>
        <% } %>

        <div class="markdown-body mt-8 rounded-[2rem] bg-white p-6 ring-1 ring-slate-200 md:p-8">
          <h2>Deskripsi</h2>
          <% if (markdownHtml) { %>
            <%- markdownHtml %>
          <% } else { %>
            <p>Belum ada deskripsi detail untuk share ini.</p>
          <% } %>
        </div>
      </article>

      <aside class="space-y-5">
        <div class="soft-card rounded-[2rem] p-6">
          <h2 class="text-2xl font-black tracking-tight">Aksi</h2>
          <p class="mt-2 text-sm font-semibold leading-relaxed text-slate-500">
            Download script atau salin kode langsung dari halaman ini.
          </p>

          <div class="mt-5 grid gap-3">
            <a href="/download/<%= share._id %>" class="btn inline-flex items-center justify-center gap-2 rounded-2xl bg-blue-600 px-5 py-4 text-center font-black text-white shadow-xl shadow-blue-600/20">
              <%- iconSvg('download', 'h-5 w-5') %>
              <%= share.type === 'code' && !share.downloadUrl ? 'Download Code' : 'Download Script' %>
            </a>
            <% if (share.type === 'code') { %>
              <button data-copy-code="#mainCode" data-share-id="<%= share._id %>" class="btn inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-4 text-center font-black text-white">
                <%- iconSvg('copy', 'h-5 w-5') %>
                Copy Code
              </button>
            <% } %>
          </div>
        </div>

        <div class="soft-card rounded-[2rem] p-6">
          <h2 class="text-2xl font-black tracking-tight">Info</h2>
          <dl class="mt-5 grid gap-4 text-sm">
            <div class="flex justify-between gap-4 border-b border-slate-200 pb-3">
              <dt class="font-black text-slate-500">Kategori</dt>
              <dd class="font-black text-slate-950"><%= categoryLabels[share.category] %></dd>
            </div>
            <div class="flex justify-between gap-4 border-b border-slate-200 pb-3">
              <dt class="font-black text-slate-500">Tipe</dt>
              <dd class="font-black text-slate-950"><%= share.type === 'code' ? 'Code' : 'Script' %></dd>
            </div>
            <% if (share.type === 'code') { %>
              <div class="flex justify-between gap-4 border-b border-slate-200 pb-3">
                <dt class="font-black text-slate-500">Bahasa</dt>
                <dd class="font-black text-slate-950"><%= languageLabels[share.language] || share.language %></dd>
              </div>
            <% } %>
            <div class="flex justify-between gap-4 border-b border-slate-200 pb-3">
              <dt class="font-black text-slate-500">Dibuat</dt>
              <dd class="font-black text-slate-950"><%= new Date(share.createdAt).toLocaleDateString('id-ID') %></dd>
            </div>
          </dl>

          <div class="mt-5 flex flex-wrap gap-2">
            <% (share.tags || []).forEach((tag) => { %>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-black text-slate-500 ring-1 ring-slate-200">#<%= tag %></span>
            <% }) %>
          </div>
        </div>

        <div class="soft-card rounded-[2rem] p-6">
          <h2 class="text-2xl font-black tracking-tight">Share Terkait</h2>
          <div class="mt-4 grid gap-3">
            <% if (!related.length) { %>
              <p class="text-sm font-semibold text-slate-500">Belum ada konten terkait.</p>
            <% } %>
            <% related.forEach((item) => { %>
              <a href="/share/<%= item.slug %>" class="rounded-2xl bg-white p-4 ring-1 ring-slate-200 transition hover:-translate-y-1 hover:shadow-lg">
                <p class="text-sm font-black text-blue-700"><%= categoryLabels[item.category] %></p>
                <h3 class="mt-1 line-clamp-2 font-black text-slate-950"><%= item.title %></h3>
                <div class="mt-3 flex flex-wrap items-center gap-3 text-xs font-black text-slate-500">
                  <span class="inline-flex items-center gap-1.5" title="View"><%- iconSvg('view', 'h-4 w-4') %><%= formatNumber(item.views) %></span>
                  <span class="inline-flex items-center gap-1.5" title="Download"><%- iconSvg('download', 'h-4 w-4') %><%= formatNumber(item.downloads) %></span>
                  <% if (item.type === 'code') { %>
                    <span class="inline-flex items-center gap-1.5" title="Copy"><%- iconSvg('copy', 'h-4 w-4') %><%= formatNumber(item.copies) %></span>
                  <% } %>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </aside>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/chat') %>
</body>
</html>
